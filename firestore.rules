// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId
// Fields:
//   - id: string (required)
//   - nome: string (required)
//   - email: string (required, email format)
//   - role: string (required, enum: ADMIN, SOCIO, GESTOR, COLABORADOR)
//   - empresa_id: string (optional)
//   - senha: string (required, hashed)
//   - primeiro_acesso: boolean (required)
//   - responsavelDiretoId: string (optional)
//
// Collection: companies
// Document ID: companyId
// Fields:
//   - id: string (required)
//   - nome: string (required)
//   - cnpj: string (optional)
//   - qualificacao: string (optional)
//   - responsavel: string (optional)
//   - status: string (optional)
//   - dataCadastro: string (optional, date format)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Função para verificar se o usuário é ADMIN
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // Regras para a coleção 'users'
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Regras para a coleção 'companies'
    match /companies/{companyId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
